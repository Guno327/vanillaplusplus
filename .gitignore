# Portable tooling downloaded by scripts, not source
.tools/

# Built pack output (regenerated via scripts/build_mrpack.py /
# scripts/build_server_bundle.py)
*.mrpack
vanilla-plus-plus-server-*.zip

# Python bytecode cache
__pycache__/

# Non-Modrinth mod jars cached/bundled by scripts/build_mrpack.py
# (embedded into the .mrpack's overrides/mods/, not tracked as source)
pack/mods/*.jar

# Server runtime (rebuilt from pack/mods.lock.json via scripts/build_server.py)
server/mods/
server/libraries/
server/versioned_datapacks/
server/world/
server/logs/
server/crash-reports/
server/*.jar
server/*.jar.log
server/eula.txt
server/run.sh
server/run.bat
server/user_jvm_args.txt
server/server.properties
server/banned-ips.json
server/banned-players.json
server/ops.json
server/usercache.json
server/whitelist.json
server/config/
server/kubejs/
server/defaultconfigs/
server/local/
server/cache/
server/patchouli_books/
server/.sable/
server/cmd_fifo
