# Gradle
.gradle/
build/
# gradle-wrapper.jar (a binary) is intentionally NOT committed - vendoring a
# binary wrapper jar isn't otherwise this repo's convention. gradlew/gradlew.bat
# (plain shell/bat scripts) ARE committed so a build environment doesn't need
# its own Gradle install just to bootstrap this one; see README.md "Build
# instructions" for the one-time `gradle wrapper` step that (re)produces the
# jar the committed scripts expect at gradle/wrapper/gradle-wrapper.jar.
gradle/wrapper/gradle-wrapper.jar

# Local compile-only jars copied in per README.md "Build instructions" -
# these are the pack's own already-hashed/pinned mods (see pack/mods.lock.json),
# not something this mod's own repo should carry a second copy of.
libs/*.jar

# IDE
.idea/
*.iml
out/
eclipse/
run/
