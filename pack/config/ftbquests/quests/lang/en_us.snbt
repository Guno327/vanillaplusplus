{"chapter.0000000000020001.title": "Rootborn", "chapter.0000000000020001.chapter_subtitle": ["The world is still just the world - for now."], "quest.0000000000020002.title": "Welcome to Vanilla++", "quest.0000000000020002.quest_desc": ["Punch some trees, then check this book after every tier-up - each chapter is a checklist for that tier's real progression."], "quest.0000000000020005.title": "Stone Age", "quest.0000000000020005.quest_desc": ["Craft your first pickaxe through Silent Gear (any material) - the first real tool upgrade."], "quest.0000000000020008.title": "First Blood", "quest.0000000000020008.quest_desc": ["Kill a zombie. Combat matters from here on - Swords XP feeds directly into the RPG skill tree."], "quest.000000000002000B.title": "Into Create's Material Chain", "quest.000000000002000B.quest_desc": ["Craft or pick up Andesite Alloy - Create's own entry material, and the trigger for Andesite Age."], "chapter.000000000002000F.title": "Andesite Age", "chapter.000000000002000F.chapter_subtitle": ["Iron enters the world. Create's own machinery begins."], "quest.0000000000020010.title": "Enter the Andesite Age", "quest.0000000000020010.quest_desc": ["Iron tools and Create's own machinery are open. This chapter is your Andesite Age checklist."], "quest.0000000000020014.title": "Iron Tools", "quest.0000000000020014.quest_desc": ["Craft another Silent Gear pickaxe with this tier's material - the real mining-speed upgrade this tier unlocks."], "quest.0000000000020018.title": "Dumb Storage", "quest.0000000000020018.quest_desc": ["Craft a Tom's Storage Inventory Connector - link your chests into one browsable network. No power, no autocrafting yet."], "quest.000000000002001C.title": "Copper Jetpack", "quest.000000000002001C.quest_desc": ["Craft the Copper Jetpack - the first rung of the personal mobility ladder (Create Stuff & Additions)."], "quest.0000000000020020.title": "Andesite Chunk Loader", "quest.0000000000020020.quest_desc": ["Craft the Andesite Chunk Loader (Create: Power Loader). It only force-loads chunks while spun under real kinetic power."], "quest.0000000000020024.title": "Vein Hunting", "quest.0000000000020024.quest_desc": ["Craft a Vein Finder (Create Ore Excavation) - the entry-level scouting tool for this pack's ore-vein system."], "quest.0000000000020028.title": "The Mage's Path", "quest.0000000000020028.quest_desc": ["Craft an Ars Nouveau wand - the entry point into this pack's spell-crafting magic system."], "quest.000000000002002C.title": "A Curious Find (optional)", "quest.000000000002002C.quest_desc": ["Find any Artifacts curio - they're pure exploration payoffs with no tier lock, hidden in structure loot at every rarity tier. This one just confirms you've found the umbrella."], "quest.000000000002002F.title": "Into the Brass Age", "quest.000000000002002F.quest_desc": ["Craft or pick up a Brass Ingot - Create's mid-game alloy, and the trigger for Brass Age."], "chapter.0000000000020033.title": "Brass Age", "chapter.0000000000020033.chapter_subtitle": ["Automation begins in earnest."], "quest.0000000000020034.title": "Enter the Brass Age", "quest.0000000000020034.quest_desc": ["Automation begins in earnest. Diamond gear, the Nether, and a real powered storage network are all open now."], "quest.0000000000020038.title": "Diamond Gear", "quest.0000000000020038.quest_desc": ["Craft another Silent Gear pickaxe with Brass Age's material - the tool-tier milestone for this age."], "quest.000000000002003C.title": "A Real Network", "quest.000000000002003C.quest_desc": ["Craft a Refined Storage Controller - the heart of the powered network that replaces Tom's Storage from here on."], "quest.0000000000020040.title": "Power the Network", "quest.0000000000020040.quest_desc": ["Craft a Create Crafts & Additions Alternator - turns Create's own rotational power into the FE that runs Refined Storage."], "quest.0000000000020044.title": "First Automation", "quest.0000000000020044.quest_desc": ["Craft a Mechanical Arm - Create's own first crafting-automation block, feeding Refined Storage's Importer/Exporter."], "quest.0000000000020048.title": "Andesite Jetpack", "quest.0000000000020048.quest_desc": ["Craft the Andesite Jetpack - fuel-fired propellers, rung 2 of the mobility ladder."], "quest.000000000002004C.title": "Brass Chunk Loader", "quest.000000000002004C.quest_desc": ["Craft the Brass Chunk Loader - the second and final Power Loader rung."], "quest.0000000000020050.title": "Time in a Bottle", "quest.0000000000020050.quest_desc": ["Craft the Time in a Bottle tick accelerator - one per player, and it won't speed up spawners."], "quest.0000000000020054.title": "Train Control", "quest.0000000000020054.quest_desc": ["Craft a Track Station - Create's own Trains are a full Brass Age package now."], "quest.0000000000020058.title": "Sharper Knives", "quest.0000000000020058.quest_desc": ["Craft a Farmer's Delight diamond knife - this is the real tier this pack's food-diet knife line reaches Brass Age (gold/diamond both unlock here; iron was Andesite Age, netherite is Precision Age)."], "quest.000000000002005C.title": "The Master Alloy", "quest.000000000002005C.quest_desc": ["Craft a Sturdy Sheet from Refined Radiance or Shadow Steel - Create's own top-tier alloy, and the door to Precision Age."], "chapter.0000000000020060.title": "Precision Age", "chapter.0000000000020060.chapter_subtitle": ["Create's own endgame alloys, and netherite gear."], "quest.0000000000020061.title": "Enter the Precision Age", "quest.0000000000020061.quest_desc": ["Create's own endgame alloys are done. Netherite gear and The End are open."], "quest.0000000000020065.title": "Netherite Gear", "quest.0000000000020065.quest_desc": ["Craft another Silent Gear pickaxe with Precision Age's material - the tool-tier milestone for this age."], "quest.0000000000020069.title": "Cut the Cables", "quest.0000000000020069.quest_desc": ["Craft a Wireless Grid - manage your Refined Storage network from anywhere in range."], "quest.000000000002006D.title": "Brass Jetpack", "quest.000000000002006D.quest_desc": ["Craft the Brass Jetpack - steam-fired, rung 3 of the mobility ladder, and the base item the Induction Age netherite jetpack smiths from."], "quest.0000000000020071.title": "Wings", "quest.0000000000020071.quest_desc": ["Find an Elytra in an End City - it's not craftable, just gated behind reaching this tier and finding one."], "quest.0000000000020075.title": "The Netherite Knife", "quest.0000000000020075.quest_desc": ["Craft a Farmer's Delight netherite knife (a smithing upgrade from the diamond knife) - the ceiling of this pack's food-diet knife line, keeping your bonus-hearts diet variety topped up through Precision Age's grind."], "quest.0000000000020079.title": "The Netherite Drill", "quest.0000000000020079.quest_desc": ["Craft the Netherite Drill - Create Ore Excavation's own tool ceiling, and what it takes to pull allthemodium/vibranium/unobtainium out of the ground."], "quest.000000000002007D.title": "The Final Ingot", "quest.000000000002007D.quest_desc": ["Craft or pick up a Netherite Ingot - the temporary trigger for Induction Age, until a real narrative trigger replaces it."], "chapter.0000000000020081.title": "Induction Age", "chapter.0000000000020081.chapter_subtitle": ["Full storage-network automation."], "quest.0000000000020082.title": "Enter the Induction Age", "quest.0000000000020082.quest_desc": ["Full storage-network automation: 64k capacity and native pattern-based autocrafting are online."], "quest.0000000000020086.title": "Native Autocrafting", "quest.0000000000020086.quest_desc": ["Craft an Autocrafting Upgrade - Refined Storage's own pattern-based autocrafter, no more Mechanical Arm needed for storage automation."], "quest.000000000002008A.title": "64k Storage", "quest.000000000002008A.quest_desc": ["Craft a 64k Storage Part - the ceiling of this pack's Refined Storage capacity chase (until the Jovian Frontier capstone)."], "quest.000000000002008E.title": "Netherite Jetpack", "quest.000000000002008E.quest_desc": ["Craft the Netherite Jetpack - the final rung before Starforged Age grants true persistent flight outright."], "quest.0000000000020092.title": "Teleportation", "quest.0000000000020092.quest_desc": ["Craft a Waystone - intra-world teleportation, gated all the way to this tier on purpose."], "quest.0000000000020096.title": "Steam-Powered Flight", "quest.0000000000020096.quest_desc": ["Craft a Steam Vent (Create Aeronautics) - the passive, industrial-scale heat source for sustained airship lift."], "quest.000000000002009A.title": "Allthemodium", "quest.000000000002009A.quest_desc": ["Smelt an Allthemodium Ingot - this pack's own post-netherite Silent Gear material floor, carrying gear progression into the space tiers."], "quest.000000000002009E.title": "Conquer the End", "quest.000000000002009E.quest_desc": ["Kill the Ender Dragon. The overworld, Nether, and End are done - this is the real trigger for Starforged Age."], "chapter.00000000000200A2.title": "Starforged Age", "chapter.00000000000200A2.chapter_subtitle": ["The overworld, Nether, and End are conquered. Space travel begins."], "quest.00000000000200A3.title": "Enter the Starforged Age", "quest.00000000000200A3.quest_desc": ["The overworld, Nether, and End are conquered. Space travel begins - and you can now toggle persistent flight outright."], "quest.00000000000200A7.title": "True Flight", "quest.00000000000200A7.quest_desc": ["Double-tap jump to toggle flight - it's granted the instant you reached this tier, no item or fuel required, and it survives death."], "quest.00000000000200AA.title": "Check Your Rank (optional)", "quest.00000000000200AA.quest_desc": ["Run /leaderboard wealth, /leaderboard tier, or /leaderboard level to see how you and your team stack up."], "quest.00000000000200AD.title": "The Aluminum Age", "quest.00000000000200AD.quest_desc": ["Smelt a TFMG Aluminum Ingot - the first rung of the endgame automation ladder that carries all the way to Jupiter."], "quest.00000000000200B1.title": "Rocket Parts", "quest.00000000000200B1.quest_desc": ["Craft a Rocket Engine (Stellaris) - one of the core components of your first rocket."], "quest.00000000000200B5.title": "Liftoff", "quest.00000000000200B5.quest_desc": ["Launch your rocket and reach Earth orbit - the real trigger for Lunar Frontier."], "chapter.00000000000200B9.title": "Lunar Frontier", "chapter.00000000000200B9.chapter_subtitle": ["You've reached orbit. The Moon is next."], "quest.00000000000200BA.title": "Enter the Lunar Frontier", "quest.00000000000200BA.quest_desc": ["You've reached orbit. The Moon is next."], "quest.00000000000200BE.title": "The Steel Age", "quest.00000000000200BE.quest_desc": ["Smelt a TFMG Steel Ingot - the mod's own core metallurgy chain, rung 2 of the endgame automation ladder."], "quest.00000000000200C2.title": "One Small Step", "quest.00000000000200C2.quest_desc": ["Travel to the Moon - the real trigger for Martian Frontier."], "chapter.00000000000200C6.title": "Martian Frontier", "chapter.00000000000200C6.chapter_subtitle": ["The Moon is conquered. Mars is next."], "quest.00000000000200C7.title": "Enter the Martian Frontier", "quest.00000000000200C7.quest_desc": ["The Moon is conquered. Mars is next."], "quest.00000000000200CB.title": "The Petrochemical Age", "quest.00000000000200CB.quest_desc": ["Refine a bucket of Diesel (TFMG) - rung 3 of the endgame automation ladder."], "quest.00000000000200CF.title": "Red Planet", "quest.00000000000200CF.quest_desc": ["Travel to Mars - the real trigger for Inner System."], "chapter.00000000000200D4.title": "Inner System", "chapter.00000000000200D4.chapter_subtitle": ["Mars is conquered. Venus and Mercury are next."], "quest.00000000000200D5.title": "Enter the Inner System", "quest.00000000000200D5.quest_desc": ["Mars is conquered. Venus and Mercury - both extreme, comparably hostile - are next."], "quest.00000000000200D9.title": "The Electrical Age", "quest.00000000000200D9.quest_desc": ["Craft a TFMG Converter - bridges TFMG's own power grid into Create/FE, rung 4 of the endgame automation ladder."], "quest.00000000000200DD.title": "Morning Star (optional)", "quest.00000000000200DD.quest_desc": ["Travel to Venus - either inner planet triggers Jovian Frontier, so this and Mercury are both optional."], "quest.00000000000200E1.title": "Swift Planet (optional)", "quest.00000000000200E1.quest_desc": ["Travel to Mercury - either inner planet triggers Jovian Frontier, so this and Venus are both optional."], "chapter.00000000000200E5.title": "Jovian Frontier", "chapter.00000000000200E5.chapter_subtitle": ["The inner system is conquered. Jupiter is the final frontier."], "quest.00000000000200E6.title": "Enter the Jovian Frontier", "quest.00000000000200E6.quest_desc": ["The inner system is conquered. Jupiter - the current edge of Stellaris' explorable system - is the final frontier."], "quest.00000000000200EA.title": "The Combustion Age", "quest.00000000000200EA.quest_desc": ["Craft a TFMG Engine Cylinder - the final rung of the endgame automation ladder."], "quest.00000000000200EE.title": "Infinite Storage", "quest.00000000000200EE.quest_desc": ["Craft a Refined Storage Creative Storage Block - genuinely infinite item capacity, the true ceiling of the storage chase started back at Andesite Age."], "quest.00000000000200F2.title": "Infinite Energy", "quest.00000000000200F2.quest_desc": ["Craft a Create Creative Motor - a genuinely endless source of Rotational Force, bridged to FE the same way every earlier power step in this pack has been."], "quest.00000000000200F6.title": "Infinite Resources", "quest.00000000000200F6.quest_desc": ["Craft a Create Creative Crate - an endless supply of any one item you configure. This is the hardest, latest-gated craft in the entire pack for a reason - guard it accordingly."], "quest.00000000000200FA.title": "Journey's End", "quest.00000000000200FA.quest_desc": ["Every tier from Rootborn to Jupiter, done. Future updates may extend the ladder further out into the solar system - this book will grow to meet them."]}
